# ── Database ────────────────────────────────────────────────────────────────
# MySQL 8 / TiDB connection string. Leave blank to run in standalone mode.
DATABASE_URL=mysql://user:password@host:3306/psyche_db

# ── Auth (JWT session cookies) ──────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# ── Manus OAuth (required for user login) ───────────────────────────────────
VITE_APP_ID=your-manus-app-id
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://manus.im
OWNER_OPEN_ID=your-manus-open-id
OWNER_NAME=Your Name

# ── App metadata ─────────────────────────────────────────────────────────────
VITE_APP_TITLE=16 Psyche Power System Simulator
VITE_APP_LOGO=

# ── LLM / AI features (optional) ─────────────────────────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# ── File storage / S3 (optional) ─────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=

# ── Analytics (optional) ─────────────────────────────────────────────────────
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ── Server port ───────────────────────────────────────────────────────────────
PORT=3000
